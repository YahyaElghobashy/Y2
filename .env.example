# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role (server-side only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web Push VAPID keys (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com  # required by edge functions that send web-push

# ── Edge Function secrets (set via: supabase secrets set KEY=value) ──
SUPABASE_ACCESS_TOKEN=    # Supabase CLI / Management API token (db push, migrations, secrets)
TMDB_API_KEY=            # tmdb-search function (Watch Together search)
MEDIA_PROXY_KEY=         # media-proxy + media-export request signing
